import java.util.*;

class Student {
    String name;
    double grade;

    Student(String name, double grade) {
        this.name = name;
        this.grade = grade;
    }

    String getGradeCategory() {
        if (grade >= 90) return "A";
        else if (grade >= 75) return "B";
        else if (grade >= 60) return "C";
        else if (grade >= 50) return "D";
        else return "F";
    }
}

public class Main {

    static Scanner scanner = new Scanner(System.in);

    public static void main(String[] args) {

        System.out.print("Enter number of students: ");
        int n = scanner.nextInt();
        scanner.nextLine();

        // ARRAY
        Student[] studentArray = new Student[n];

        // Input
        for (int i = 0; i < n; i++) {
            System.out.println("\nStudent " + (i + 1));

            System.out.print("Enter name: ");
            String name = scanner.nextLine();

            System.out.print("Enter grade: ");
            double grade = scanner.nextDouble();
            scanner.nextLine();

            studentArray[i] = new Student(name, grade);
        }

        // ARRAYLIST
        ArrayList<Student> studentList = new ArrayList<>();
        for (Student s : studentArray) {
            studentList.add(s);
        }

        int choice;

        do {
            System.out.println("\n===== MENU =====");
            System.out.println("1. View Students (Array)");
            System.out.println("2. View Students (ArrayList)");
            System.out.println("3. Show Statistics");
            System.out.println("4. Display Summary Report");
            System.out.println("5. Exit");
            System.out.print("Enter choice: ");

            choice = scanner.nextInt();

            switch (choice) {

                case 1:
                    System.out.println("\n--- Students (Array) ---");
                    for (int i = 0; i < studentArray.length; i++) {
                        System.out.println((i + 1) + ". " +
                                studentArray[i].name + " - " +
                                studentArray[i].grade);
                    }
                    break;

                case 2:
                    System.out.println("\n--- Students (ArrayList) ---");
                    for (int i = 0; i < studentList.size(); i++) {
                        Student s = studentList.get(i);
                        System.out.println((i + 1) + ". " +
                                s.name + " - " +
                                s.grade + " (" + s.getGradeCategory() + ")");
                    }
                    break;

                case 3:
                    showStatistics(studentList);
                    break;

                case 4:
                    displaySummaryReport(studentList);
                    break;

                case 5:
                    System.out.println("Exiting...");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }

        } while (choice != 5);
    }

    static void showStatistics(ArrayList<Student> list) {
        if (list.isEmpty()) {
            System.out.println("No data available.");
            return;
        }

        double total = 0;
        double highest = Double.MIN_VALUE;
        double lowest = Double.MAX_VALUE;
        String topStudent = "";
        String lowStudent = "";

        for (Student s : list) {
            total += s.grade;

            if (s.grade > highest) {
                highest = s.grade;
                topStudent = s.name;
            }

            if (s.grade < lowest) {
                lowest = s.grade;
                lowStudent = s.name;
            }
        }

        double avg = total / list.size();

        System.out.println("\n--- Statistics ---");
        System.out.println("Average: " + avg);
        System.out.println("Highest: " + highest + " (" + topStudent + ")");
        System.out.println("Lowest: " + lowest + " (" + lowStudent + ")");
    }

    static void displaySummaryReport(ArrayList<Student> list) {
        if (list.isEmpty()) {
            System.out.println("No data available.");
            return;
        }

        double total = 0;
        double highest = Double.MIN_VALUE;
        double lowest = Double.MAX_VALUE;
        String topStudent = "";
        String lowStudent = "";

        System.out.println("\n====== SUMMARY REPORT ======");
        System.out.println("Name\tGrade\tCategory");

        for (Student s : list) {
            System.out.println(s.name + "\t" + s.grade + "\t" + s.getGradeCategory());

            total += s.grade;

            if (s.grade > highest) {
                highest = s.grade;
                topStudent = s.name;
            }

            if (s.grade < lowest) {
                lowest = s.grade;
                lowStudent = s.name;
            }
        }

        double avg = total / list.size();

        System.out.println("\n----- Overall -----");
        System.out.println("Average: " + avg);
        System.out.println("Highest: " + highest + " (" + topStudent + ")");
        System.out.println("Lowest: " + lowest + " (" + lowStudent + ")");
    }
}
